# ------------------------------------------------------------
# Nivora backend (Laravel) environment — EXAMPLE
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#   php artisan key:generate
#
# NEVER commit a real .env, a database password, or any app secret.
# ------------------------------------------------------------

APP_NAME=Nivora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# URL of the Next.js frontend — used to build the CORS allow-list.
FRONTEND_URL=http://localhost:3000

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------
# Database — PostgreSQL hosted on Supabase
#
# In the Supabase dashboard: Project Settings -> Database ->
# "Connection string" / "Connection pooling". Use the pooler host
# in SESSION mode (port 5432) so that migrations run correctly.
#
#   Host:     aws-0-<region>.pooler.supabase.com
#   Port:     5432
#   Database: postgres
#   Username: postgres.<your-project-ref>
#   Password: <your-database-password>
#
# SSL is required by Supabase.
# ------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=
DB_SSLMODE=require

# Token-based API (Sanctum personal access tokens) — no server sessions.
SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@nivora.test"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Seeder demo accounts (ASSESSMENT ONLY — override as needed).
# DatabaseSeeder reads these to create the admin and customer
# demo accounts. Do NOT put real credentials here.
# ------------------------------------------------------------
ADMIN_NAME="Nivora Admin"
ADMIN_EMAIL=admin@nivora.test
ADMIN_PASSWORD=password

DEMO_NAME="Demo Customer"
DEMO_EMAIL=customer@nivora.test
DEMO_PASSWORD=password
