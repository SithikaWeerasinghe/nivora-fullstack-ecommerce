# ------------------------------------------------------------
# Nivora frontend environment (PUBLIC values only)
#
# Copy this file to `.env.local` and adjust as needed:
#   cp .env.example .env.local
#
# Only NEXT_PUBLIC_* (public, non-secret) values belong here.
# Never place database credentials, API secrets, or auth tokens
# in the frontend environment — those live in the backend only.
# ------------------------------------------------------------

# Base URL of the Laravel REST API, including the /api prefix (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8000/api
