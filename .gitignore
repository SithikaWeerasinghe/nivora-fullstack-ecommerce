# ============================================================
#  Nivora — root .gitignore
#  Covers the Next.js frontend and the Laravel backend.
# ============================================================

# ----- Operating system -----
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ----- Editors / IDEs -----
.idea/
.fleet/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ----- Environment files (NEVER commit real secrets) -----
.env
.env.*
!.env.example

# ----- Node / Next.js (frontend/) -----
node_modules/
.next/
out/
build/
.turbo/
*.tsbuildinfo
next-env.d.ts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel

# ----- PHP / Laravel (backend/) -----
/backend/vendor/
/backend/node_modules/
/backend/public/build/
/backend/public/hot
/backend/public/storage
/backend/storage/*.key
/backend/.phpunit.result.cache
/backend/.phpunit.cache/
/backend/composer.phar
/backend/auth.json
/backend/.php-cs-fixer.cache

# ----- Documentation artifacts -----
/docs/screenshots/*.tmp
